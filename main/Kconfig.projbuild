menu "Remote OTA (WiFi)"

    config OTA_WIFI_SSID
        string "WiFi SSID"
        default "CU_s6PR"
        help
            设备连接的路由器 SSID（局域网 OTA 用）

    config OTA_WIFI_PASSWORD
        string "WiFi Password"
        default ""
        help
            WiFi 密码

    config OTA_DEVICE_NAME_PREFIX
        string "Device name prefix"
        default "MaiQing-C3"
        help
            设备名前缀，完整名为 前缀-SN后6位，同时用于 mDNS 主机名

    config OTA_HTTP_PORT
        int "HTTP server port"
        default 80
        range 80 65535

endmenu

menu "Joystick"

    config JOYSTICK_ENABLE_TEST
        bool "Boot into joystick test (skip WiFi/OTA UI)"
        default n
        help
            上电后仅初始化 LCD 与摇杆，进入测试界面并在串口打印按键事件。
            默认关闭，正常启动为 WiFi/OTA/设备信息界面。
            需要标定时在 menuconfig 中开启，或 sdkconfig 中设置
            CONFIG_JOYSTICK_ENABLE_TEST=y 后重新编译。

endmenu

menu "LED"

    config LED_ENABLE_BLINK
        bool "Enable D4/D5 LED blink test task"
        default n
        help
            D4(GPIO12)、D5(GPIO13)，高电平有效；D4 每 1s、D5 每 2s 翻转。
            默认关闭，正常为设备信息界面。需要时在 menuconfig 开启，或
            sdkconfig 中设置 CONFIG_LED_ENABLE_BLINK=y 后重新编译。
            D5 与摇杆 UP(IO13) 共用，测试 LED 时请关闭摇杆测试。
            详见 docs/LED.md

endmenu
